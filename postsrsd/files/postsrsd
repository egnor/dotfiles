# Managed by pyinfra. Source: postsrsd/files/postsrsd
# Defaults file for the postsrsd Sender Rewriting Scheme daemon.
# Reference: man postsrsd  /  /usr/share/doc/postsrsd/
#
# Purpose:
#   When this host forwards mail (external → root@eacs.io →
#   egnor@ofb.net, or external → admin@blackletterlabs.com →
#   drain.teaser@gmail.com), the envelope-from would normally still be
#   the original external sender. The next-hop forwarder SPF-checks
#   that sender's domain against eacs.io's IP, which fails. SRS rewrites
#   envelope-from to an encoded form under eacs.io so SPF aligns; bounces
#   coming back are decoded so they reach the original sender.
#
#   Mail ORIGINATING from one of our domains (shop@seventeengames.com
#   submitting via SASL, cron from root@eacs.io, etc.) is left alone —
#   those flows already align under the local domain's own SPF.
#
# Wiring (postfix/files/main.cf):
#   {sender,recipient}_canonical_maps point at tcp:127.0.0.1:{10001,10002}.
#   Forward port rewrites envelope-from on outbound; reverse port decodes
#   SRS-encoded recipients on inbound bounces.

# Domain that owns the rewritten envelopes (the @ side of the SRS form).
SRS_DOMAIN=eacs.io

# Senders at these domains are left alone — they're already "ours" and
# don't need SRS to align under eacs.io. ofb.net is here because this
# host is ofb.net's outbound :25 relay (ofb sits on GCE, which blocks
# outbound :25), and ofb.net's SPF authorizes 104.200.25.248 directly
# (`a:egnor-2020.ofb.net`). Rewriting @ofb.net to @eacs.io would still
# pass SPF, but would break SPF *alignment* under DMARC and force
# reliance on DKIM-only alignment. Leaving it alone keeps both
# alignment paths available. Other ofb-hosted domains are NOT in this
# list — when we see them in envelope-from, it's because ofb forwarded
# mail with a (probably-forged) third-party sender, exactly the case
# SRS is designed to rewrite.
SRS_EXCLUDE_DOMAINS=eacs.io,approximately.competent.services,blackletterlabs.com,seventeengames.com,0b10001.com,ofb.net

# HMAC secret. Auto-generated by the Debian/Ubuntu package on first
# install (mode 0600, owner=postsrs). Anyone with this file can forge
# SRS-encoded envelope-from addresses that decode to arbitrary recipients
# on bounce, so it stays out of the repo. Rotating it invalidates
# in-flight SRS-encoded bounces — rare operation, do it cold.
SRS_SECRET=/etc/postsrsd.secret

# Loopback-only listener; postfix queries via tcp:127.0.0.1.
SRS_LISTEN_ADDR=127.0.0.1
SRS_FORWARD_PORT=10001
SRS_REVERSE_PORT=10002
