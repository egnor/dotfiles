server {
    server_name 17g.io www.17g.io;
    include /etc/nginx/snippets/tls-0b10001.conf;

    location = / {
        return 301 https://shop.seventeengames.com/;
    }
    location ~ /(.+) {
        return 301 https://seventeengames.com/scan.html?id=$1;
    }
}
