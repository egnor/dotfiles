server {
    server_name blackletterlabs.com;
    listen [::]:443 ssl;
    listen 443 ssl;
    rewrite ^/admin(/(.*))? https://api.blackletterlabs.com/_/$2;
    location = / {
        try_files /index.html =404;
    }
    location = /iap.html {
        return 301 https://iap.blackletterlabs.com/$is_args$args;
    }

    add_header Access-Control-Allow-Origin *;
    root /home/egnor/www-blackletterlabs;
    error_page 404 =200 /catch.html;

    ssl_certificate /etc/letsencrypt/live/blackletterlabs.com-0001/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/blackletterlabs.com-0001/privkey.pem;
}

