# Managed by pyinfra. Source: dotfiles/nginx/files/sites-enabled/drain-teaser
# Domains for "Drain Teaser" game.
#
# All :80 -> :443 redirects are handled by the global default in
# sites-enabled/http-redirect; only :443 servers live here. TLS + ACME
# boilerplate is factored into the per-cert snippets included below.

server {
    server_name blackletterlabs.com;
    include /etc/nginx/snippets/tls-blackletterlabs.conf;
    rewrite ^/admin(/(.*))? https://api.blackletterlabs.com/_/$2;
    location = /iap.html {
        return 301 https://iap.blackletterlabs.com/$is_args$args;
    }

    add_header Access-Control-Allow-Origin *;
    root /home/egnor/www-blackletterlabs;
    error_page 404 =200 /catch.html;
}

server {
    server_name iap.blackletterlabs.com;
    include /etc/nginx/snippets/tls-blackletterlabs.conf;
    rewrite ^/pb(/(.*))? https://api.blackletterlabs.com/_/$2;

    add_header Access-Control-Allow-Origin *;
    root /home/egnor/prod-blackletterlabs-iap/www_root;
}

# admin.blackletterlabs.com — the redirect lives in `location /` (not a
# server-level `return`) so it doesn't short-circuit the ACME location.
server {
    server_name admin.blackletterlabs.com;
    include /etc/nginx/snippets/tls-blackletterlabs.conf;
    location / {
        return 301 https://iap.blackletterlabs.com/admin.html;
    }
}

server {
    server_name api.blackletterlabs.com;
    include /etc/nginx/snippets/tls-blackletterlabs.conf;
    location / {
        proxy_set_header X-Real-IP $remote_addr;
        # Pin to IPv4 — PocketBase listens on 127.0.0.1:8090, but `localhost`
        # was resolving to [::1] and producing 502s for real clients.
        proxy_pass http://127.0.0.1:8090;
    }
}

server {
    server_name www.blackletterlabs.com blackletterlab.com www.blackletterlab.com blacklettergame.com www.blacklettergame.com blackletterfortress.com www.blackletterfortress.com;
    include /etc/nginx/snippets/tls-blackletterlabs.conf;
    location / {
        return 301 https://blackletterlabs.com$request_uri;
    }
}

server {
    server_name seventeengames.com;
    include /etc/nginx/snippets/tls-0b10001.conf;

    location = / {
        return 301 https://shop.seventeengames.com/;
    }

    root /home/egnor/www-seventeengames;
    add_header Access-Control-Allow-Origin *;
    error_page 404 =200 /catch.html;
}

# 0b10001.com - outro site for the final Drain Teaser capstone puzzle.
server {
    server_name 0b10001.com;
    include /etc/nginx/snippets/tls-0b10001.conf;
    root /home/egnor/www-0b10001;

    # The content must be cross-origin isolated, or the embedded
    # mac.0b10001.com iframe drops to the slow (no SharedArrayBuffer) path.
    add_header Cross-Origin-Opener-Policy   "same-origin"  always;
    add_header Cross-Origin-Embedder-Policy "require-corp" always;

    # serve /deception.html for /deception (no suffix needed)
    try_files $uri $uri/ $uri.html =404;
}

# mac.0b10001.com — the self-hosted infinite-mac emulator.
server {
    server_name mac.0b10001.com;
    include /etc/nginx/snippets/tls-0b10001.conf;
    root /home/egnor/www-0b10001-mac;

    # Needs cross-origin isolation (COOP+COEP) for full-speed SharedArrayBuffer,
    # a cross-origin CORP so 0b10001.com can embed it, and an SPA fallback so
    # client-routed paths like /embed resolve to index.html.
    add_header Cross-Origin-Opener-Policy   "same-origin"   always;
    add_header Cross-Origin-Embedder-Policy "require-corp"  always;
    add_header Cross-Origin-Resource-Policy "cross-origin"  always;
    add_header Service-Worker-Allowed       "/"             always;

    # Content-hashed assets and disk chunks are immutable. A nested location's
    # own add_header resets the inherited ones, so repeat the isolation headers.
    location ~ ^/(assets|Disk)/ {
        add_header Cross-Origin-Opener-Policy   "same-origin"   always;
        add_header Cross-Origin-Embedder-Policy "require-corp"  always;
        add_header Cross-Origin-Resource-Policy "cross-origin"  always;
        add_header Cache-Control "public, max-age=31536000, immutable" always;
    }

    # SPA: /embed (and friends) are client-routed -> serve index.html.
    location / { try_files $uri /index.html; }
}

server {
    server_name www.seventeengames.com;
    include /etc/nginx/snippets/tls-0b10001.conf;
    location / {
        return 301 https://seventeengames.com$request_uri;
    }
}

server {
    server_name www.0b10001.com;
    include /etc/nginx/snippets/tls-0b10001.conf;
    location / {
        return 301 https://0b10001.com$request_uri;
    }
