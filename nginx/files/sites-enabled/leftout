  ssl_certificate_key /etc/letsencrypt/live/jolly.teamleftout.org/privkey.pem;
  include /etc/letsencrypt/options-ssl-nginx.conf;
  ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
  listen [::]:80;
  listen 80;
  return 301 https://jolly.teamleftout.org$request_uri;
