# Managed by pyinfra. Source: dotfiles/nginx/files/sites-enabled/leftout

# teamleftout.org
server {
    server_name teamleftout.org www.teamleftout.org;
    listen [::]:80;
    listen 80;
    return 301 https://teamleftout.org$request_uri;
}

server {
    server_name teamleftout.org www.teamleftout.org;
    root /home/leftout/www.teamleftout.org;
    index index.html;

    listen [::]:443 ssl;
    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/www.teamleftout.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/www.teamleftout.org/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

# czar.teamleftout.org
server {
    listen [::]:80;
    listen 80;
    server_name czar.teamleftout.org www.czar.teamleftout.org;
    return 301 https://czar.teamleftout.org$request_uri;
}

server {
    server_name czar.teamleftout.org www.czar.teamleftout.org;
    root /home/leftout/czar.teamleftout.org;
    index index.html;

    auth_basic "Same master login as puzzletron";
    auth_basic_user_file /home/leftout/htpasswd;

    location /stateserver/ {
        proxy_buffering off;
        proxy_pass http://127.0.0.1:433/;
    }

    listen [::]:443 ssl;
    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/czar.teamleftout.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/czar.teamleftout.org/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

