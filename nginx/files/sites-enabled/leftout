# Managed by pyinfra. Source: dotfiles/nginx/files/sites-enabled/leftout

# teamleftout.org
server {
    server_name teamleftout.org www.teamleftout.org;
    include /etc/nginx/snippets/acme-challenge.conf;
    root /home/leftout/www.teamleftout.org;
    index index.html;

    listen [::]:443 ssl;
    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/www.teamleftout.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/www.teamleftout.org/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

# czar.teamleftout.org
server {
    server_name czar.teamleftout.org www.czar.teamleftout.org;
    root /home/leftout/czar.teamleftout.org;
    index index.html;

    auth_basic "Same master login as puzzletron";
    auth_basic_user_file /home/leftout/htpasswd;

    location /stateserver/ {
        proxy_buffering off;
        proxy_pass http://127.0.0.1:433/;
    }

    include /etc/nginx/snippets/tls-czar.conf;
}

# czarchat.teamleftout.org
server {
    server_name czarchat.teamleftout.org www.czarchat.teamleftout.org;
    root /home/leftout/czarchat.teamleftout.org;
    index index.html;

    auth_basic "Same master login as puzzletron";
    auth_basic_user_file /home/leftout/htpasswd;

    include /etc/nginx/snippets/tls-czar.conf;
}

# slack.teamleftout.org
server {
    listen [::]:80;
    listen 80;
    server_name slack.teamleftout.org www.slack.teamleftout.org;
    return 301 https://leftout.slack.com$request_uri;
}

# jolly.teamleftout.org — Jolly Roger app for an annual event; the upstream
# on :3000 is offline most of the year. Map upstream-down errors to a 200
# placeholder so the parade of bot probes against this domain doesn't show
# up as 5xx noise in monitoring.
server {
  server_name jolly.teamleftout.org jollyroger.teamleftout.org jolly-roger.teamleftout.org jr.teamleftout.org roger.teamleftout.org;
  include /etc/nginx/snippets/acme-challenge.conf;
  listen [::]:443 ssl;
  listen 443 ssl;

  if ($host != 'jolly.teamleftout.org') {
    return 301 https://jolly.teamleftout.org$request_uri;
  }
  location / {
    error_page 502 503 504 = @offline;
    proxy_pass http://127.0.0.1:3000/;
  }
  location @offline {
    default_type text/plain;
    return 200 "Jolly Roger is offline outside event season.\n";
  }

  ssl_certificate /etc/letsencrypt/live/jolly.teamleftout.org/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/jolly.teamleftout.org/privkey.pem;
  include /etc/letsencrypt/options-ssl-nginx.conf;
  ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}
