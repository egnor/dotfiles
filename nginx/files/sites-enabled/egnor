# nutrimatic
server {
  server_name nutrimatic.org www.nutrimatic.org;

  gzip off;
  fastcgi_buffering off;
  fastcgi_connect_timeout 5s;
  fastcgi_send_timeout 30s;
  fastcgi_read_timeout 300s;

  # Limit concurrent FastCGI requests (fcgiwrap has 10 workers)
  limit_conn perserver 8;
  limit_conn_status 503;

  location / {
    rewrite ^/(.*)$ https://nutrimatic.org/2024/$1 redirect;
  }

  location /2016 {
    alias /home/egnor/prod-nutrimatic/web_static/;
    location = /2016/ {
      fastcgi_pass unix:/var/run/fcgiwrap.socket;
      include /etc/nginx/fastcgi_params;
      fastcgi_param SCRIPT_FILENAME /home/egnor/prod-nutrimatic/cgi_scripts/cgi-search.py;
      fastcgi_param NUTRIMATIC_FIND_EXPR /home/egnor/prod-nutrimatic/bin/find-expr;
      fastcgi_param NUTRIMATIC_INDEX /home/egnor/prod-nutrimatic/prod-2016.index;
    }
  }

  location /2024 {
    alias /home/egnor/prod-nutrimatic/web_static/;
    location = /2024/ {
      fastcgi_pass unix:/var/run/fcgiwrap.socket;
      include /etc/nginx/fastcgi_params;
      fastcgi_param SCRIPT_FILENAME /home/egnor/prod-nutrimatic/cgi_scripts/cgi-search.py;
      fastcgi_param NUTRIMATIC_FIND_EXPR /home/egnor/prod-nutrimatic/bin/find-expr;
      fastcgi_param NUTRIMATIC_INDEX /home/egnor/prod-nutrimatic/prod-2024.index;
    }
  }

  location /staging {
    alias /home/egnor/staging/web_static/;
    location = /staging/ {
      fastcgi_pass unix:/var/run/fcgiwrap.socket;
      include /etc/nginx/fastcgi_params;
      fastcgi_param SCRIPT_FILENAME /home/egnor/staging-nutrimatic/cgi_scripts/cgi-search.py;
      fastcgi_param NUTRIMATIC_FIND_EXPR /home/egnor/staging-nutrimatic/bin/find-expr;
      fastcgi_param NUTRIMATIC_INDEX /home/egnor/staging-nutrimatic/wiki-merged.index;
    }
  }

  listen [::]:443 ssl;
  listen 443 ssl;
  ssl_protocols TLSv1 TLSv1.1 TLSv1.2;
  ssl_prefer_server_ciphers on;
  ssl_ciphers 'EECDH+AESGCM:EDH+AESGCM:AES256+EECDH:AES256+EDH';
  ssl_certificate /etc/letsencrypt/live/nutrimatic.org/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/nutrimatic.org/privkey.pem;
}

server {
  listen [::]:80;
  listen 80;
  server_name nutrimatic.org www.nutrimatic.org;
  return 301 https://nutrimatic.org$request_uri;
}

