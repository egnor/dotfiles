# robotmolecule.com
server {
  server_name robotmolecule.com www.robotmolecule.com;
  root /home/anaulin/www/robotmolecule;
  index index.html;

  listen [::]:443 ssl;
  listen 443 ssl;
  ssl_certificate /etc/letsencrypt/live/robotmolecule.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/robotmolecule.com/privkey.pem;
  include /etc/letsencrypt/options-ssl-nginx.conf;
  ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
  server_name robotmolecule.com www.robotmolecule.com;
  listen [::]:80;
  listen 80;
  return 301 https://robotmolecule.com$request_uri;
}

