# Managed by pyinfra. Source: dotfiles/nginx/files/sites-enabled/netdata

# netdata.eacs.io — reverse proxy to the local Netdata dashboard
# (Netdata listens on 127.0.0.1:19998; *:19999 stays streaming-only for children.)
# Cert is the shared `competent.services` SAN cert (covers eacs.io et al).
server {
  server_name netdata.eacs.io;
  include /etc/nginx/snippets/acme-challenge.conf;
  listen [::]:443 ssl;
  listen 443 ssl;
  ssl_certificate /etc/letsencrypt/live/competent.services/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/competent.services/privkey.pem;

  auth_basic "Netdata";
  auth_basic_user_file /etc/nginx/htpasswd-netdata;

  location / {
    proxy_pass http://127.0.0.1:19998;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_buffering off;
    proxy_pass_request_headers on;
  }
}

server {
  server_name netdata.eacs.io;
  listen [::]:80;
  listen 80;
  return 301 https://netdata.eacs.io$request_uri;
}
